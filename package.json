{
  "name": "mini-cms",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3200",
    "build": "next build",
    "start": "next start",
    "start:prod": "next start -p 3201",
    "lint": "eslint",
    "test:rls": "node scripts/test-rls.mjs",
    "test:rls:mutate": "node scripts/test-rls.mjs --mutate",
    "test:lib": "node --disable-warning=MODULE_TYPELESS_PACKAGE_JSON scripts/test-lib.mjs",
    "test": "npm run test:lib && npm run test:rls",
    "check:supabase": "node --env-file=.env.local --disable-warning=MODULE_TYPELESS_PACKAGE_JSON scripts/check-supabase.mjs",
    "migrate:sql": "node --disable-warning=MODULE_TYPELESS_PACKAGE_JSON scripts/migrate-print.mjs",
    "backup": "node --env-file=.env.local --disable-warning=MODULE_TYPELESS_PACKAGE_JSON scripts/backup.mjs",
    "restore": "node --env-file=.env.local --disable-warning=MODULE_TYPELESS_PACKAGE_JSON scripts/restore.mjs",
    "tenant:create": "node --env-file=.env.local --disable-warning=MODULE_TYPELESS_PACKAGE_JSON scripts/tenant-create.mjs",
    "tenant:list": "node --env-file=.env.local --disable-warning=MODULE_TYPELESS_PACKAGE_JSON scripts/tenant-toggle.mjs list",
    "tenant:enable": "node --env-file=.env.local --disable-warning=MODULE_TYPELESS_PACKAGE_JSON scripts/tenant-toggle.mjs enable",
    "tenant:disable": "node --env-file=.env.local --disable-warning=MODULE_TYPELESS_PACKAGE_JSON scripts/tenant-toggle.mjs disable"
  },
  "dependencies": {
    "@supabase/ssr": "^0.12.3",
    "@supabase/supabase-js": "^2.110.7",
    "next": "16.2.10",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "server-only": "^0.0.1"
  },
  "devDependencies": {
    "@electric-sql/pglite": "^0.5.4",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.10",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
