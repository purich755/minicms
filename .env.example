# Скопируй этот файл в .env.local и подставь значения из панели Supabase
# (Project Settings → API). .env.local в git не попадает.

# --- Публичные (уходят в браузер, это нормально) ---
# URL проекта, вида https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_URL=

# Анонимный ключ. У новых проектов Supabase он называется publishable
# и выглядит как sb_publishable_... — кладётся сюда же.
# Ключ безопасен для браузера ТОЛЬКО потому, что данные закрыты RLS-политиками.
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# --- Секретные (только сервер, никогда не в браузер) ---
# Service role обходит RLS полностью. У новых проектов — sb_secret_...
# Пока не используется: появится, когда будем заводить тенантов из кода.
# Никогда не импортируй его в файл с 'use client'.
# SUPABASE_SERVICE_ROLE_KEY=
